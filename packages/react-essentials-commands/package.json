{
  "name": "@agusmgarcia/react-essentials-commands",
  "core": "lib",
  "version": "0.15.1",
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.node.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/outputs/*.d.ts",
      "node": "./dist/outputs/*.node.js",
      "default": "./dist/outputs/*.js"
    },
    "./tsconfig.json": "./tsconfig.json"
  },
  "author": "Agus Garcia",
  "description": "Set of opinionated commands for NextJS applications, libraries and Azure functions",
  "bin": {
    "react-essentials-commands-build": "bin/build.js",
    "react-essentials-commands-check": "bin/check.js",
    "react-essentials-commands-deploy": "bin/deploy.js",
    "react-essentials-commands-format": "bin/format.js",
    "react-essentials-commands-regenerate": "bin/regenerate.js",
    "react-essentials-commands-start": "bin/start.js",
    "react-essentials-commands-test": "bin/test.js"
  },
  "scripts": {
    "build": "tsx src/binaries/build.ts",
    "check": "tsx src/binaries/check.ts",
    "deploy": "tsx src/binaries/deploy.ts --path=../../.github/workflows",
    "format": "tsx src/binaries/format.ts",
    "postbuild": "chmod +x bin/*.js",
    "prebuild": "npm i --ignore-scripts --no-audit --no-fund",
    "prepack": "move-cli tsconfig.json tsconfig.json2 && move-cli src/outputs/tsconfig.base.json tsconfig.json",
    "postpack": "move-cli tsconfig.json src/outputs/tsconfig.base.json && move-cli tsconfig.json2 tsconfig.json",
    "regenerate": "tsx src/binaries/regenerate.ts --path=../../.github/workflows",
    "start": "tsx src/binaries/start.ts",
    "test": "tsx src/binaries/test.ts"
  },
  "dependencies": {
    "@next/env": "^16.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0 || ^19.0.0",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.0.0",
    "css-loader": "^7.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-project-structure": "^3.0.0",
    "eslint-plugin-sort": "^4.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "next": "^16.0.0",
    "postcss-loader": "^8.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "semver": "^7.0.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "ts-loader": "^9.0.0",
    "ts-transform-paths": "^3.0.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^6.0.0",
    "yaml": "^2.0.0"
  },
  "peerDependencies": {
    "ts-node": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "~18.18.0",
    "@types/semver": "^7.7.1",
    "move-cli": "^2.0.0",
    "tsx": "^4.21.0"
  },
  "files": [
    "bin",
    "dist",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agusmgarcia/react-essentials.git"
  }
}
