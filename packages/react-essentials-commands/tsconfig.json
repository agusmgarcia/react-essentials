{
  "extends": "./src/outputs/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "./",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "#src/*": ["src/*"]
    },
    "rootDir": "./src"
  },
  "exclude": ["*.ts", ".next", "bin", "dist", "node_modules"],
  "include": ["**/*.ts", "**/*.tsx"]
}
