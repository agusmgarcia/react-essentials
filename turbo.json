{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*",
        "!src/**/*.test.*",
        "package.json",
        "webpack.config.ts"
      ],
      "outputs": ["bin", "dist"]
    },
    "check": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": [
        "src/**/*.test.*",
        "eslint.config.js",
        "jest.config.js",
        "postcss.config.js",
        "prettier.config.js",
        "tsconfig.json"
      ]
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["check", "test"]
    },
    "format": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": [
        "src/**/*.test.*",
        "eslint.config.js",
        "jest.config.js",
        "postcss.config.js",
        "prettier.config.js",
        "tsconfig.json"
      ]
    },
    "test": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["jest.config.js", "src/**/*.test.*"]
    }
  }
}
